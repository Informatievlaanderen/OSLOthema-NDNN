prefixes:
  ex: https://example.com/
  ex-sensor: https://example.com/sensor/
  melding: https://data.vlaanderen.be/ns/melding#
  dcterms: http://purl.org/dc/terms/
  oa: http://www.w3.org/ns/oa#
  schema: https://schema.org/
  xsd: http://www.w3.org/2001/XMLSchema#
  prov: http://www.w3.org/ns/prov#
  time: http://www.w3.org/2006/time#
  sosa: http://www.w3.org/ns/sosa/
  rdf: http://www.w3.org/1999/02/22-rdf-syntax-ns#
  rdfs: http://www.w3.org/2000/01/rdf-schema#
  locn: http://www.w3.org/ns/locn#
  adms: http://www.w3.org/ns/adms#
  skos: http://www.w3.org/2004/02/skos/core#
  qudt: http://qudt.org/3.2.0/vocab/unit/
mappings:
  sensoren:
    sources:
      - ['sensoren.csv~csv']
    s: ex-sensor:$(Object.id)
    po:
      - [a, sosa:Sensor] # Klasse Sensor
      - [prov:atLocation, ex-sensor:$(Object.id)#ligging~iri] # Sensor.ligging (Plaats)

  sensoren-ligging:
    sources:
      - ['sensoren.csv~csv']
    s: ex-sensor:$(Object.id)#ligging
    po:
      - [a, dcterms:Location] # Klasse Plaats
      - [rdfs:label, $(t_sec_nl), nl~lang] # Plaats.plaatsnaam
